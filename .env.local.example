# Clerk authentication (public key only, safe for frontend)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...

# Backend API URL (nginx gateway — routes to microservices)
NEXT_PUBLIC_API_URL=https://api.saanvicareers.com

# EmailJS configuration
NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_...
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_...
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_public_key

# Business configuration
NEXT_PUBLIC_WHATSAPP_NUMBER=918074172398
NEXT_PUBLIC_CHAT_API_URL=https://saanvi-chat-api.vercel.app/api/chat

# Anthropic API key (server-side only)
ANTHROPIC_API_KEY=sk-ant-...
